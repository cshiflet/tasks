# Reproduces the sandbox toolchain we've been using for
# `desktop-native/`. Not a 1:1 VM snapshot (Anthropic's web-hosted
# Claude Code sandbox isn't exportable from inside), but the
# resulting image has every package the branch builds, tests, and
# smoke-tests against.
#
# Build:
#   docker build -t tasks-dev -f desktop-native/docker/Dockerfile.dev .
#
# Run with repo mounted:
#   docker run --rm -it -v "$PWD":/workspace -w /workspace tasks-dev bash
#
# Inside the container:
#   cd desktop-native
#   cargo test --workspace
#   QT_QPA_PLATFORM=offscreen cargo run -p tasks-ui       # GUI (headless)
#   cargo run -p tasks-ui -- --cli path/to/tasks.db        # data-layer only

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    CARGO_HOME=/root/.cargo \
    RUSTUP_HOME=/root/.rustup \
    PATH=/root/.cargo/bin:$PATH

# Qt 6.4.2 ships in Ubuntu 24.04 (noble); matches the sandbox build.
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        clang \
        cmake \
        curl \
        git \
        libqt6svg6-dev \
        libsqlite3-dev \
        libssl-dev \
        pkg-config \
        qml6-module-qt-labs-platform \
        qml6-module-qtqml-workerscript \
        qml6-module-qtquick \
        qml6-module-qtquick-controls \
        qml6-module-qtquick-dialogs \
        qml6-module-qtquick-layouts \
        qml6-module-qtquick-templates \
        qml6-module-qtquick-window \
        qt6-base-dev \
        qt6-declarative-dev \
        qt6-tools-dev \
        qt6-tools-dev-tools \
    && rm -rf /var/lib/apt/lists/*

# Rustup + stable toolchain (1.94.x at the time of writing). The
# `default` profile already installs clippy + rustfmt, so don't pass
# `--component` — rustup-init errors on the second positional arg.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain stable --profile default \
    && rustc --version && cargo --version \
    && rustfmt --version && cargo clippy --version

WORKDIR /workspace
CMD ["bash"]
